#!/bin/bash
# =============================================================================
# Per-user configuration for the local <-> HPC sync scripts.
# =============================================================================
# This is a TEMPLATE. Copy it to `tools/pull_config.sh` (gitignored) and
# edit it for your local setup:
#
#   cp tools/pull_config.sh.example tools/pull_config.sh
#   nano tools/pull_config.sh
#
# Used by: pull_from_hpc.sh, push_to_hpc.sh
# =============================================================================

# -----------------------------------------------------------------------------
# SSH username on HPC
# -----------------------------------------------------------------------------
HPC_USER="<your-username>"

# -----------------------------------------------------------------------------
# SSH hostname (or alias) for HPC
# -----------------------------------------------------------------------------
# Option A — SSH alias (recommended, cleaner).
#   Add to ~/.ssh/config on the local machine:
#     Host hpc
#         HostName <your-hpc-hostname>
#         User <your-username>
#   Then this is enough:
HPC_HOST="hpc"

# Option B — Full hostname (no alias).
#   HPC_HOST="<your-hpc-hostname>"

# -----------------------------------------------------------------------------
# Repository path on HPC (absolute, not `~`)
# -----------------------------------------------------------------------------
# Examples:
#   /home/<user>/projects/local-concept-sliders
#   /scratch/<user>/local-concept-sliders
HPC_REPO="/home/<your-username>/path/to/local-concept-sliders"

# -----------------------------------------------------------------------------
# Repository path on the local machine
# -----------------------------------------------------------------------------
# Default: ~/Desktop/local-concept-sliders. Change it if the clone lives
# somewhere else.
LOCAL_REPO="$HOME/Desktop/local-concept-sliders"
