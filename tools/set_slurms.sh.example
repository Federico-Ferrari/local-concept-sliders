#!/bin/bash
# =============================================================================
# Per-user HPC configuration loaded by every SLURM job in the repo.
# =============================================================================
# This is a TEMPLATE. Copy it to `tools/set_slurms.sh` (gitignored) and
# edit it to match your HPC setup:
#
#   cp tools/set_slurms.sh.example tools/set_slurms.sh
#   nano tools/set_slurms.sh
#
# Every SLURM template starts with `source $SLURM_SUBMIT_DIR/tools/set_slurms.sh`,
# so the same job files work for any user (each one provides their own
# venv / conda / mamba / paths via this file).
# =============================================================================

# -----------------------------------------------------------------------------
# Repository path on HPC (use the absolute path, not `~`, to avoid tilde
# expansion issues in contexts where it is not expanded).
# -----------------------------------------------------------------------------
# Examples:
#   /home/<user>/projects/local-concept-sliders
#   /scratch/<user>/local-concept-sliders
export FERT_REPO=/home/<your-username>/path/to/local-concept-sliders

# Add the repository root to PYTHONPATH so Python can resolve the
# `sdxl` and `flux` packages used by the scripts (they all rely on
# absolute imports like `from sdxl.core.lora import ...`).
export PYTHONPATH="$FERT_REPO:${PYTHONPATH:-}"

# -----------------------------------------------------------------------------
# HuggingFace cache
# -----------------------------------------------------------------------------
# Where the base models (Flux.1-dev ~25 GB, SDXL ~7 GB) and other
# pretrained weights are stored. Pick a writable, large-enough location.
# Examples:
#   /home/<user>/caches/hf_cache
#   /home/<user>/.cache/huggingface         (the HF default; watch out for home quotas)
#   /scratch/<user>/hf_cache
export FERT_HF_CACHE=/home/<your-username>/caches/hf_cache

# -----------------------------------------------------------------------------
# Python environment activation functions
# -----------------------------------------------------------------------------
# Define them according to your environment manager (venv, conda, mamba, ...).
# The SLURM templates simply call `activate_flux_env` or `activate_sdxl_env`
# without knowing which one is in use.
# Uncomment ONE of the examples below and comment the others.

# --- Example 1: venv ---------------------------------------------------------
activate_flux_env() {
    source /home/<your-username>/venvs/flux_env/bin/activate
}

activate_sdxl_env() {
    source /home/<your-username>/venvs/sdxl_env/bin/activate
}

# --- Example 2: conda --------------------------------------------------------
# activate_flux_env() {
#     source /home/<your-username>/miniconda3/etc/profile.d/conda.sh
#     conda activate flux_env
# }
#
# activate_sdxl_env() {
#     source /home/<your-username>/miniconda3/etc/profile.d/conda.sh
#     conda activate sdxl_env
# }

# --- Example 3: mamba (faster than conda) ------------------------------------
# activate_flux_env() {
#     source /home/<your-username>/mambaforge/etc/profile.d/mamba.sh
#     mamba activate flux_env
# }
#
# activate_sdxl_env() {
#     source /home/<your-username>/mambaforge/etc/profile.d/mamba.sh
#     mamba activate sdxl_env
# }

# --- Example 4: mixed (Flux on conda, SDXL on venv) --------------------------
# activate_flux_env() {
#     source /home/<your-username>/miniconda3/etc/profile.d/conda.sh
#     conda activate flux_env
# }
#
# activate_sdxl_env() {
#     source /home/<your-username>/venvs/sdxl_env/bin/activate
# }

# --- Example 5: module load (Lmod-based clusters) ----------------------------
# activate_flux_env() {
#     module load python/3.10
#     source /home/<your-username>/envs/flux_env/bin/activate
# }
#
# activate_sdxl_env() {
#     module load python/3.10
#     source /home/<your-username>/envs/sdxl_env/bin/activate
# }
