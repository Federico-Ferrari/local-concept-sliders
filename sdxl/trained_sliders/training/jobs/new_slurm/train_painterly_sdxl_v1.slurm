#!/bin/bash
#SBATCH --job-name=painterly_sdxl_v1
#SBATCH --partition=stud
#SBATCH --qos=stud
#SBATCH --gpus=1
#SBATCH --cpus-per-task=4
#SBATCH --mem=24G
#SBATCH --time=03:00:00
#SBATCH --output=sdxl/trained_sliders/training/logs/%x_%j.out
#SBATCH --error=sdxl/trained_sliders/training/logs/%x_%j.err

# =============================================================================
# train_painterly_sdxl_v1.slurm
# =============================================================================
# Realistic-to-painterly slider — general scenes (no subject localization).
#
# Setup:
#   - 10 entries: diverse scene types (landscape, city, portrait, beach, etc.)
#   - positive=painterly/oil painting, unconditional=hyperrealistic photo, neutral=photo
#   - rank 4, alpha 1.0, noxattn
#   - guidance_scale 4, resolution 1024, 1000 iterations
#   - start_noise 750 (as in original repo generate_images_xl.py default)
#
# Test: scale -2 0 2, seed 42
#   - 4 prompts: landscape, portrait, village, city
#   - scale < 0: more hyperrealistic / scale > 0: more painterly
#
# Output slider:
#   sdxl/trained_sliders/sliders/painterly_sdxl_v1_alpha1.0_rank4_noxattn/
#     painterly_sdxl_v1_alpha1.0_rank4_noxattn_last.safetensors
# =============================================================================

set -euo pipefail

source $SLURM_SUBMIT_DIR/tools/set_slurms.sh
cd $FERT_REPO
activate_sdxl_env

export HF_HOME=$FERT_HF_CACHE
export HF_HUB_CACHE=$FERT_HF_CACHE/hub
export HF_HUB_OFFLINE=1
export TRANSFORMERS_OFFLINE=1

echo "================================================================"
echo "=== PHASE 1: TRAINING painterly_sdxl_v1                       ==="
echo "================================================================"
nvidia-smi
echo ""

python sdxl/trained_sliders/training/scripts/train.py \
    --config_file sdxl/trained_sliders/training/configs/painterly_sdxl_v1.yaml \
    --name painterly_sdxl_v1 \
    --rank 4 \
    --alpha 1.0 \
    --device 0

echo ""
echo "=== Training completed ==="
SLIDER_DIR="sdxl/trained_sliders/sliders/painterly_sdxl_v1_alpha1.0_rank4_noxattn"
SLIDER="${SLIDER_DIR}/painterly_sdxl_v1_alpha1.0_rank4_noxattn_last.safetensors"
ls -lh "$SLIDER_DIR"

echo ""
echo "================================================================"
echo "=== PHASE 2: POST-TRAINING TEST                                ==="
echo "================================================================"

TEST_ROOT="sdxl/tasks/baseline/outputs/painterly_sdxl_v1_test"

run_test() {
    local PROMPT="$1"
    local SUBDIR="$2"
    local OUT="${TEST_ROOT}/${SUBDIR}"
    mkdir -p "$OUT"
    echo "--- Test: '${PROMPT}' -> ${OUT} ---"
    python sdxl/tasks/baseline/scripts/generate_with_sliders.py \
        --prompt "$PROMPT" \
        --slider "$SLIDER" \
        --save_path "$OUT" \
        --scales -2 0 2 \
        --start_noise 750 \
        --rank 4 \
        --alpha 1.0 \
        --seed 42 \
        --steps 50
}

run_test "a photo of a landscape with mountains and a river, sharp focus, 4k" "landscape"
run_test "a photo of a portrait of a person, sharp focus, 4k"                 "portrait"
run_test "a photo of a village with red rooftops, sharp focus, 4k"            "village"
run_test "a photo of a city street, sharp focus, 4k"                          "city"

echo ""
echo "================================================================"
echo "=== JOB COMPLETED                                            ==="
echo "=== Output slider: ${SLIDER_DIR}                              ==="
echo "=== Output test:   ${TEST_ROOT}                               ==="
echo "================================================================"
ls -lh "$TEST_ROOT"
