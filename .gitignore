# =============================================================================
# .gitignore — local-concept-sliders
# =============================================================================

# --- Trained LoRA weights / sliders (large, regenerable from training) ---
*.pt
*.safetensors

# --- SAM / pretrained models (multi-GB, downloadable) ---
*.pth
mask_SAM/checkpoints/

# --- SLURM logs (stdout/stderr) ---
# The logs/ directories exist in the repo (with .gitkeep) but their content does not.
**/logs/*
!**/logs/.gitkeep

# --- PEFT cache (auto-generated, recreatable) ---
**/_peft_cache/

# --- Personal HPC config (each user has their own, DO NOT commit) ---
tools/set_slurms.sh
tools/pull_config.sh

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.pytest_cache/

# --- Virtual environments ---
.venv*/
venv*/
env/
ENV/

# --- Local HuggingFace cache (in case it ever ends up in the repo) ---
.hf_cache/
hf_cache/

# --- Jupyter ---
.ipynb_checkpoints/

# --- macOS junk ---
.DS_Store
._*

# --- Editor / IDE ---
.idea/
.vscode/
*.swp
*.swo
*~

# --- Personal jobs (not shared) ---
sdxl/tasks/masked_lora/jobs/personal/
sdxl/tasks/selectivity/jobs/personal/
flux/trained_sliders/training/jobs/personal/
flux/tasks/masked_lora/jobs/personal/

# --- Reference material (original notebooks, not part of the project) ---
flux/trained_sliders/training/reference/

# --- Local SAM masks (distributed into run dirs via place_masks.py) ---
masks_output/

# --- Run directory contents (large PNG images — transferred separately) ---
# The runs/ dirs exist with .gitkeep, but the eval_* subdirectories are generated on HPC.
sdxl/tasks/masked_lora/runs/eval_*/
sdxl/tasks/selectivity/runs/eval_*/
flux/tasks/masked_lora/runs/eval_*/

# --- Temporary files ---
*.bak
*.tmp

# --- Paper PDFs (kept locally only, not part of the code submission) ---
2311.12092v2.pdf
2505.23758v1.pdf

# --- Paper template directory (not part of the code submission) ---
author-kit-CVPR2026-v1-latex-/

# --- Local working screenshots / paper figure drafts (kept locally only) ---
img paper/
paper_foto_masked/
paper_foto_achored/

# --- Final sliders used in paper experiments (whitelist) ---
!sdxl/trained_sliders/sliders/general/**/*.safetensors
!sdxl/trained_sliders/sliders/anchored/**/*.safetensors
!flux/trained_sliders/sliders/general/**/*.pt
!flux/trained_sliders/sliders/anchored/**/*.pt
